# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
venv/
env/
.venv/

# Data — don't commit large audio datasets or LMDB training databases
data/processed/*
!data/processed/kicks.pt
data/*.mdb/
data/*.mdb-lock/

# Training outputs (checkpoints, logs, exported models)
outputs/*
!outputs/vae/
outputs/vae/*
!outputs/vae/.gitkeep
!outputs/vae/kick_vae_final.pt

# Audio files — drop your own kicks in data/raw/ but don't commit them
*.wav
*.mp3
*.flac
*.aiff
*.aif
*.ogg

# Keep the raw dir placeholder
!data/raw/.gitkeep

# Tensor dataset — excluded from gitignore so kicks.pt is tracked
# data/processed/*.pt

# PyTorch
*.pt
*.pth
*.ts

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Jupyter
.ipynb_checkpoints/
data/prepared/
